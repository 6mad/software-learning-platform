{
    "name": "user/software-learning-platform",
    "description": "A platform for learning software usage through simulation",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.0",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "nyholm/psr7": "^1.0",
        "nyholm/psr7-server": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs src/",
        "cs-fix": "phpcbf src/",
        "start": "php -S localhost:8000 -t public/"
    }
}